# ─────────────────────────────────────────────────────────────────────────────
# RecipeReel configuration. Copy to `.env` and fill in. NEVER commit `.env`.
# Every var has a safe default; with none set, the app runs in MOCK mode offline.
# ─────────────────────────────────────────────────────────────────────────────

# App
APP_NAME=RecipeReel
ENV=development                 # development | production
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# Global offline switch. true => every stage uses its mock/fixture impl (no GPU,
# no network, no keys). Great for demos, CI, and laptop dev. Leave false to use
# real providers where configured below.
MOCK_MODE=false

# ── Fireworks AI (recipe synthesis + optional vision) ───────────────────────────
# Key: unlock the $50 hackathon credit at https://app.fireworks.ai/fire-pass with your
# invite code, then create a key (Settings→API Keys). Used via OpenAI-compatible endpoint.
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Text synthesis model for the Fireworks path.
#  Verified Jul 2026: Gemma is NOT on Fireworks serverless (404). The hackathon Fire Pass
#  ($50 coupon) grants GLM 5.2 Fast + Kimi only, and the account must have a payment method
#  added to activate (credits then cover usage). GLM 5.2 Fast is a solid text synthesizer:
SYNTH_MODEL=accounts/fireworks/routers/glm-5p2-fast
#  (Kimi alt: accounts/fireworks/routers/kimi-k2p7-code-fast)
#  For GEMMA + the "Best AMD-Hosted Gemma" prize, use SYNTHESIZER=amd (self-host on MI300X).

# VISION=fireworks needs a MULTIMODAL model; none is on Fire Pass, so on this plan prefer
# VISION=local (Qwen2.5-VL on the MI300X) or VISION=none. This is only used if VISION=fireworks:
VISION_FIREWORKS_MODEL=accounts/fireworks/routers/glm-5p2-fast

# ── FREE real Gemma, NO credit card (Google AI Studio) — VERIFIED WORKING ───────
# The providers are endpoint-agnostic. Run a REAL per-video recipe with zero cost / no
# card / no GPU using Gemini for vision + Gemma for synthesis (both free on one key):
#   1) free key (no card): https://aistudio.google.com/apikey
#   2) set:
# SYNTHESIZER=fireworks
# FIREWORKS_API_KEY=<your Google AI Studio key>
# FIREWORKS_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# SYNTH_MODEL=gemma-4-31b-it              # real Gemma-4 does the structured recipe (verified)
# VISION=fireworks
# VISION_FIREWORKS_MODEL=gemini-2.5-flash # reads real frames + on-screen text (verified)
# TRANSCRIBER=none                        # vision-only, no GPU; or =local for Whisper spoken steps (needs torch)
# Notes: Gemma-4 IS the model id on Google (gemma-3 is not served). Gemma via this endpoint is
# text-only (images 500), so vision uses Gemini — synthesis still uses Gemma. This is real Gemma
# but NOT "AMD-hosted"; for the $2k AMD-Hosted Gemma prize run Gemma on the MI300X (SYNTHESIZER=amd).

# ── Provider selection ──────────────────────────────────────────────────────────
# transcriber:  local | none | mock
TRANSCRIBER=local
# vision:       local | fireworks | none | mock
VISION=local
# synthesizer:  fireworks | amd | mock
SYNTHESIZER=fireworks

# ── Local models (run on AMD MI300X via ROCm, or CPU fallback) ──────────────────
WHISPER_MODEL=openai/whisper-large-v3       # use whisper-small/base on CPU laptops
VISION_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
HF_TOKEN=                                    # for gated weights / faster HF downloads
# Force device: auto | cuda | cpu  (auto = GPU if torch.cuda.is_available())
DEVICE=auto

# ── Media / pipeline tuning ─────────────────────────────────────────────────────
MAX_VIDEO_SECONDS=1800          # reject videos longer than this
MAX_UPLOAD_MB=512
MAX_KEYFRAMES=24                # scene-cut frames sampled for vision
SCENE_THRESHOLD=27.0            # PySceneDetect ContentDetector threshold
YTDLP_COOKIES_FROM_BROWSER=     # e.g. "chrome" for login-walled IG/TikTok (optional)
YTDLP_COOKIES_FILE=             # path to a cookies.txt (server-side login-wall unblock)
YTDLP_PROXY=                    # scheme://user:pass@host:port — residential/ISP/mobile proxy to
                                # beat YouTube's datacenter-IP bot wall. Secret: real value in .env only.
# ── YouTube ingest (SocialKit hosted download API — preferred on a datacenter host) ─────────────
SOCIALKIT_API_KEY=              # hosted YT download that dodges the datacenter-IP bot wall. Secret → .env only.
SOCIALKIT_QUALITY=360p          # 240p|360p|480p|720p|1080p (lower = fits the per-file size cap)
YOUTUBE_INGEST_ENABLED=true     # kill-switch: set false to cleanly disable YT links (clients told to upload)

# ── Storage ─────────────────────────────────────────────────────────────────────
DATA_DIR=./data                 # sqlite db + working files live here
DATABASE_URL=sqlite:///./data/recipereel.db
