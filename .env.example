# ─────────────────────────────────────────────────────────────────────────────
# RecipeReel configuration. Copy to `.env` and fill in. NEVER commit `.env`.
# Every var has a safe default; with none set, the app runs in MOCK mode offline.
# ─────────────────────────────────────────────────────────────────────────────

# App
APP_NAME=RecipeReel
ENV=development                 # development | production
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# Global offline switch. true => every stage uses its mock/fixture impl (no GPU,
# no network, no keys). Great for demos, CI, and laptop dev. Leave false to use
# real providers where configured below.
MOCK_MODE=false

# ── Fireworks AI (recipe synthesis + optional vision) ───────────────────────────
# Key: unlock the $50 hackathon credit at https://app.fireworks.ai/fire-pass with your
# invite code, then create a key (Settings→API Keys). Used via OpenAI-compatible endpoint.
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Text synthesis model.
#  • Gemma (default) — targets the $2k "Best AMD-Hosted Gemma" prize; needs serverless
#    credits, or host it yourself (SYNTHESIZER=amd). Alternates: gemma-4-26b-a4b-it, gemma-4-31b-it-nvfp4
#  • Fire Pass only? Gemma isn't included — use a Fire Pass text model instead:
#      accounts/fireworks/routers/glm-5p2-fast   (or accounts/fireworks/routers/kimi-k2p7-code-fast)
#    Fire Pass models are TEXT-ONLY, so set VISION=local (on the MI300X) or VISION=none.
SYNTH_MODEL=accounts/fireworks/models/gemma-4-31b-it

# Multimodal model used ONLY when VISION=fireworks (separate from SYNTH_MODEL above, so a
# text-only synth model still works). Must be a vision-capable model.
VISION_FIREWORKS_MODEL=accounts/fireworks/models/gemma-4-31b-it

# ── Provider selection ──────────────────────────────────────────────────────────
# transcriber:  local | mock
TRANSCRIBER=local
# vision:       local | fireworks | none | mock
VISION=local
# synthesizer:  fireworks | mock
SYNTHESIZER=fireworks

# ── Local models (run on AMD MI300X via ROCm, or CPU fallback) ──────────────────
WHISPER_MODEL=openai/whisper-large-v3       # use whisper-small/base on CPU laptops
VISION_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
HF_TOKEN=                                    # for gated weights / faster HF downloads
# Force device: auto | cuda | cpu  (auto = GPU if torch.cuda.is_available())
DEVICE=auto

# ── Media / pipeline tuning ─────────────────────────────────────────────────────
MAX_VIDEO_SECONDS=1800          # reject videos longer than this
MAX_UPLOAD_MB=512
MAX_KEYFRAMES=24                # scene-cut frames sampled for vision
SCENE_THRESHOLD=27.0            # PySceneDetect ContentDetector threshold
YTDLP_COOKIES_FROM_BROWSER=     # e.g. "chrome" for login-walled IG/TikTok (optional)

# ── Storage ─────────────────────────────────────────────────────────────────────
DATA_DIR=./data                 # sqlite db + working files live here
DATABASE_URL=sqlite:///./data/recipereel.db
