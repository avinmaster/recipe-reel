# RecipeReel — full GPU image for the AMD Instinct MI300X (ROCm).
# Runs local Whisper-large-v3 ASR + Qwen2.5-VL frame analysis on the GPU, then
# synthesizes with Gemma (Fireworks, or a local vLLM Gemma via SYNTHESIZER=amd).
#
# Uses AMD's official ROCm PyTorch image (torch already built for gfx942/MI300X —
# torch.cuda.is_available() is True; ROCm/HIP masquerades as CUDA).
#
#   docker build -f Dockerfile.rocm -t recipereel:rocm .
#   docker run --device=/dev/kfd --device=/dev/dri --group-add video \
#       -p 8000:8000 --env-file .env recipereel:rocm
FROM rocm/pytorch:latest

ENV PYTHONUNBUFFERED=1 PIP_NO_CACHE_DIR=1

RUN apt-get update && apt-get install -y --no-install-recommends ffmpeg nodejs \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Core + GPU perception deps (torch/torchaudio already in the base image).
COPY requirements.txt requirements-gpu.txt ./
RUN pip install --no-cache-dir -r requirements.txt \
    && pip install --no-cache-dir -r requirements-gpu.txt

COPY app ./app
COPY fixtures ./fixtures
COPY README.md LICENSE ./

EXPOSE 8000
ENV DATA_DIR=/data DATABASE_URL=sqlite:////data/recipereel.db \
    TRANSCRIBER=local VISION=local SYNTHESIZER=fireworks
VOLUME ["/data"]

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
